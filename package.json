  "scripts": {
    "be:build": "docker compose up -d server --build",
    "be:dev": "docker compose --profile stego_backend up -w",
    "build": "docker compose up --profile app --build",
    "db:build": "docker compose up -d postgres --build",
    "db:stop": "docker compose stop postgres",
    "db:stop-clean": "docker compose stop postgres && rm -rf server/postgres/data",
